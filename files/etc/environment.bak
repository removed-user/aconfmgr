XDG_CONFIG_DIRS=/etc/xdg
VISUAL=nvim
EDITOR=nvim
REPOCTL_CONFIG=/etc/pacman.d/repoctl/config.toml
AUR_ROOT=/var/cache/AurBuild/Repos
BAT_THEME=Dracula
EDITOR=nvim
VISUAL=nvim
SYSTEMD_EDITOR=nvim
ACLOCAL_PATH=/etc/build_config.d/aclocal:/usr/share/aclocal-1.18/
LANG=en_US.UTF-8
CPU_FAMILY=X86_64
CPU=X86_64
LC_CTYPE=C.UTF-8
LC_COLLATE=C.UTF-8
LC_ALL=C.UTF-8
WARNINGS='obsolete,error'
INTLTOOLIZE=/bin/true
LINGUAS="en"
AR=/bin/ar
AS=/bin/as
LD=/bin/ld
NM=/bin/nm
STRIP=/bin/strip
RANLIB=/bin/ranlib
