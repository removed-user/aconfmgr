#runs after prepare, unsets pkgdir
pkgver() {
  cd "${SRCDIR}"
  local _major=$(sed 's/[~.].*//g' meson.version)
  printf "%s.r%s" "${_major}" "$(git rev-list --count HEAD)"

}

