prepare() {

  cd "${_systemd_src_dir}"

  # Replace cdrom/dialout/tape groups with optical/uucp/storage
  patch -Np1 -i ../0001-Use-Arch-Linux-device-access-groups.patch

  # return if not a git repository
  if ! git status >/dev/null 2>&1; then
    return
  fi

  local _c _l
  for _c in "${_backports[@]}"; do
    if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
    git log --oneline "${_l}" "${_c}"
    git cherry-pick --mainline 1 --no-commit "${_c}"
  done
  for _c in "${_reverts[@]}"; do
    if [[ "${_c}" == *..* ]]; then _l='--reverse'; else _l='--max-count=1'; fi
    git log --oneline "${_l}" "${_c}"
    git revert --mainline 1 --no-commit "${_c}"
  done
for package in "${pkgname}"; do mkdir -p "${_PACKAGE_DIR}";done

  # If the primary clone failed or is empty, try mirrors in order
#  if [[ ! -d "${srcdir}/.git" ]]; then
#    echo "==> Primary source unavailable, trying mirrors..."
#    for _mirror in "${_mirrors[@]}"; do
#      echo "  -> Trying ${_mirror}..."
#      if git clone --depth=1 "$_mirror" "${srcdir}"; then
#        echo "  -> Cloned from ${_mirror}"
#        break
#      fi
#    done
#  fi


#mkdir -p "${SRCDEST}" || /bin/true
#mkdir -p "${SRCDIR}" || /bin/true
#mkdir -p "${SRCPKGDEST}" || /bin/true
#mkdir -p "${BUILDDIR}" || /bin/true
#mkdir -p "${PKGDIR}" || /bin/true

  cd "${srcdir}"

}


