function where_the_fuck_am_I() {

_OUTPUTS="${SRCDIR}"/outputs
BUILDDIR="${_OUTPUTS}"/build
_PKGNAME=$(echo "${FUNCNAME[1]}" | sed 's#package_##g' )
_PACKAGE_DIR="${_OUTPUTS}"/"${_PKGNAME}"
  printf srcdir\="${srcdir}"'\n'pkgdir\="${pkgdir}"'\n'srcdest\="${srcdest}"'\n'pwd\=$(pwd)'\n'BUILDDIR\="${BUILDDIR}"'\n'_PACKAGE_DIR\="${_PACKAGE_DIR}"'\n'Current_Function\="${FUNCNAME[1]}"  2>&1 | tee "${FUNCNAME[0]}"_1
  cd "${srcdir}"                                                                                                                    
  printf srcdir\="${srcdir}"'\n'pkgdir\="${pkgdir}"'\n'srcdest\="${srcdest}"'\n'pwd\=$(pwd)'\n'BUILDDIR\="${BUILDDIR}"'\n'_PACKAGE_DIR\="${_PACKAGE_DIR}"'\n'Current_Function\="${FUNCNAME[1]}"  2>&1 | tee "${FUNCNAME[0]}"_2
  cd "${SRCDIR}"                                                                                                                   
  printf srcdir\="${srcdir}"'\n'pkgdir\="${pkgdir}"'\n'srcdest\="${srcdest}"'\n'pwd\=$(pwd)'\n'BUILDDIR\="${BUILDDIR}"'\n'_PACKAGE_DIR\="${_PACKAGE_DIR}"'\n'Current_Function\="${FUNCNAME[1]}"  2>&1 | tee "${FUNCNAME[0]}"_3
  cd "${BUILDDIR}"                                                                                                                
  printf srcdir\="${srcdir}"'\n'pkgdir\="${pkgdir}"'\n'srcdest\="${srcdest}"'\n'pwd\=$(pwd)'\n'BUILDDIR\="${BUILDDIR}"'\n'_PACKAGE_DIR\="${_PACKAGE_DIR}"'\n'Current_Function\="${FUNCNAME[1]}"  2>&1 | tee "${FUNCNAME[0]}"_4
 [[ -z  "${pkgdir}" ]] && export pkgdir="${_PACKAGE_DIR}" 
